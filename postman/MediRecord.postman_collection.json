    {
      "name": "Token QR",
      "item": [
        {
          "name": "POST /api/ficha/token/revoke - revocar y regenerar token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Devuelve ok:true y new_token', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.ok).to.equal(true);",
                  "    pm.expect(body).to.have.property('new_token');",
                  "    pm.expect(body.new_token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('revoked_token', pm.collectionVariables.get('qr_token'));",
                  "    pm.collectionVariables.set('qr_token', body.new_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{auth_token}}" }],
            "url": "{{base_url}}/api/ficha/token/revoke"
          }
        },
        {
          "name": "GET /api/emergency/:token - token revocado retorna 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403 para token revocado', () => pm.response.to.have.status(403));",
                  "",
                  "pm.test('Mensaje indica que fue revocado', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.detail).to.include('revocado');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/emergency/{{revoked_token}}"
          }
        },
