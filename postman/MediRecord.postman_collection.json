{
  "info": {
    "name": "MediRecord API",
    "description": "Colección de pruebas para todos los endpoints de MediRecord. Ejecutar con Newman: newman run MediRecord.postman_collection.json -e MediRecord.postman_environment.json",
    "_postman_id": "medirecord-sqa-grupo5-2026",
