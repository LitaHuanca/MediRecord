                  "pm.test('Devuelve datos de emergencia válidos', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('nombre_completo');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/emergency/{{qr_token}}"
          }
        },
